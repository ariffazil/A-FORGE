# AF FORGE — Caddy Reverse Proxy
# Public entrypoint: only Caddy faces the internet. All backend services are internal.

:80 {
	bind 0.0.0.0

	# Health check for gateway itself
	health /healthz

	# arifOS MCP governance kernel
	reverse_proxy /mcp arifos-mcp:8080
	reverse_proxy /arifos/* arifos-mcp:8080

	# AF FORGE bridge server — operator, sense, metrics, human escalation
	reverse_proxy /operator/* af-forge-bridge:7071
	reverse_proxy /metrics af-forge-bridge:7071
	reverse_proxy /sense af-forge-bridge:7071
	reverse_proxy /human-expert/* af-forge-bridge:7071
	reverse_proxy /health af-forge-bridge:7071
	reverse_proxy /ready af-forge-bridge:7071

	# Default respond
	respond "AF FORGE Gateway" 200
}
