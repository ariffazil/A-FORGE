# AF-FORGE Agent Plane — Environment Variables
# Copy to .env and fill in the values
# DITEMPA BUKAN DIBERI

# ── Vault ──────────────────────────────────────────────────────────
POSTGRES_URL=postgresql://arifos_admin:YOUR_PASSWORD@arifos-postgres:5432/arifos_vault
POSTGRES_PASSWORD=ArifPostgresVault2026!

# ── Agent Identity ─────────────────────────────────────────────────
AGENT_ID=AF-FORGE-Agent
CONSTITUTION_HASH=SEAL20260413RESOURCECONSOLIDATION

# ── Telegram Notifier (888_HOLD alerts) ────────────────────────────
# Get from @BotFather: t.me/BotFather
TELEGRAM_BOT_TOKEN=
# Your Telegram chat ID: get from @userinfobot
TELEGRAM_CHAT_ID=
# Optional: Matrix/Slack webhook as fallback
TELEGRAM_ALERT_WEBHOOK_URL=

# ── Backup ─────────────────────────────────────────────────────────
# Local retention in days
BACKUP_RETENTION=30
# Off-box target (rsync path or S3 bucket). Leave empty to skip.
BACKUP_OFFBOX_TARGET=
# Example rsync: user@backup-host:/var/backups/arifos/
# Example S3: s3://your-bucket/arifos-backups/

# ── Prometheus Scraping ─────────────────────────────────────────────
# node-exporter: http://localhost:9100/metrics
# cadvisor: http://localhost:8080/metrics
# arifOS metrics: http://localhost:7071/metrics
